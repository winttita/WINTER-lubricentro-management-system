name: Build Windows Release

on:
  push:
    tags:
      - 'v*'

permissions:
  contents: write

jobs:
  build-windows:
    runs-on: windows-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.12'

      - name: Install PyInstaller
        run: pip install pyinstaller

      - name: Extract version from tag
        id: version
        run: echo "VERSION=${GITHUB_REF#refs/tags/v}" >> $GITHUB_OUTPUT

      - name: Build launcher.exe
        run: |
          python -m PyInstaller --onefile --windowed --noconfirm --name LubricentroWinter `
            --distpath dist `
            --workpath build `
            --specpath build `
            build/launcher.py

      - name: Download embedded Python
        shell: pwsh
        run: |
          $PYVER = "3.12.7"
          $PYARCH = "amd64"
          $PYURL = "https://www.python.org/ftp/python/$PYVER/python-$PYVER-embed-$PYARCH.zip"
          $PYZIP = "dist/python-embed.zip"
          Invoke-WebRequest -Uri $PYURL -OutFile $PYZIP
          Expand-Archive -Force -Path $PYZIP -DestinationPath dist/runtime
          # Enable pip in embedded python
          Get-ChildItem dist/runtime/python*._pth | Rename-Item -NewName { $_.Name + ".disabled" }
          if (!(Test-Path dist/runtime/get-pip.py)) {
            Invoke-WebRequest -Uri 'https://bootstrap.pypa.io/get-pip.py' -OutFile dist/runtime/get-pip.py
          }
          & dist/runtime/python.exe get-pip.py --no-warn-script-location

      - name: Install dependencies in embedded Python
        run: |
          dist/runtime/python.exe -m pip install --no-warn-script-location -r requirements.txt

      - name: Prepare release package
        shell: pwsh
        run: |
          $VERSION = "${{ steps.version.outputs.VERSION }}"
          $STAGE = "dist/LubricentroWinter_v$VERSION"
          $ZIP = "dist/LubricentroWinter_v$VERSION.zip"

          if (Test-Path $STAGE) { Remove-Item -Recurse -Force $STAGE }
          if (Test-Path $ZIP) { Remove-Item -Force $ZIP }
          New-Item -ItemType Directory -Path $STAGE | Out-Null

          # Copy launcher.exe
          Copy-Item dist/LubricentroWinter.exe $STAGE/

          # Copy runtime (embedded Python + deps)
          Copy-Item dist/runtime $STAGE/ -Recurse

          # Copy app source
          New-Item -ItemType Directory -Path "$STAGE/app" | Out-Null
          Copy-Item app.py $STAGE/app/
          Copy-Item database.py $STAGE/app/
          Copy-Item pages $STAGE/app/pages -Recurse
          Copy-Item updater.py $STAGE/
          Copy-Item requirements.txt $STAGE/

          # Create ZIP
          Compress-Archive -Path "$STAGE\*" -DestinationPath $ZIP -Force

          echo "STAGE=$STAGE" >> $GITHUB_ENV
          echo "ZIP=$ZIP" >> $GITHUB_ENV

      - name: Create GitHub Release
        uses: softprops/action-gh-release@v2
        with:
          tag_name: ${{ github.ref }}
          name: Lubricentro Winter - v${{ steps.version.outputs.VERSION }}
          files: ${{ env.ZIP }}
          generate_release_notes: true
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}